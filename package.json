{
  "name": "neuroasistente-tdah",
  "version": "0.1.0",
  "description": "Dashboard PWA para adultos con TDAH - Desarrollado por 15 agentes OpenClaw",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "orchestrate": "node scripts/orquestador.js",
    "research": "node scripts/orquestador.js research",
    "qa": "node scripts/orquestador.js qa",
    "deploy": "npm run build && npm run deploy:frontend && npm run deploy:backend",
    "deploy:frontend": "cd frontend && vercel --prod",
    "deploy:backend": "cd backend && railway up",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "prisma:studio": "cd backend && npx prisma studio",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "prisma:generate": "cd backend && npx prisma generate"
  },
  "keywords": [
    "tdah",
    "neurodiversity",
    "pwa",
    "dashboard",
    "productivity",
    "mental-health",
    "openclaw",
    "ai-agents"
  ],
  "author": "Equipo NeuroAsistente TDAH <cuervoc-openclaw>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cuervoc-openclaw/TDAH-DASHBOARD.git"
  },
  "bugs": {
    "url": "https://github.com/cuervoc-openclaw/TDAH-DASHBOARD/issues"
  },
  "homepage": "https://github.com/cuervoc-openclaw/TDAH-DASHBOARD#readme",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}