{
  "name": "neuroasistente-tdah",
  "version": "1.0.0",
  "description": "Dashboard PWA para adultos con TDAH - Desarrollado por 15 agentes OpenClaw",
  "private": true,
  "scripts": {
    "dev": "concurrently \"cd frontend && npm run dev\" \"cd backend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "deploy:vercel": "./deploy-vercel.sh",
    "deploy:gh-pages": "cd frontend && npm run build:gh-pages",
    "test": "cd frontend && npm test",
    "lint": "cd frontend && npm run lint",
    "format": "cd frontend && npm run format",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:seed": "cd backend && npx prisma db seed",
    "db:studio": "cd backend && npx prisma studio",
    "agents:run": "node scripts/orquestador.js",
    "setup": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "keywords": [
    "tdah",
    "neurodiversity",
    "pwa",
    "dashboard",
    "productivity",
    "openclaw",
    "ai-agents"
  ],
  "author": "David Salas <zionylenodavid@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuervoc-openclaw/TDAH-DASHBOARD.git"
  },
  "bugs": {
    "url": "https://github.com/cuervoc-openclaw/TDAH-DASHBOARD/issues"
  },
  "homepage": "https://cuervoc-openclaw.github.io/TDAH-DASHBOARD/",
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/cuervoc-openclaw"
  }
}